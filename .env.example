# TikTok 爆款内容引擎 — API Key 配置
# 复制这个文件为 .env，然后填入你的真实 Key

# Apify — 抓取 TikTok 数据（https://apify.com → Settings → API Tokens）
APIFY_TOKEN=apify_api_xxxxx

# Groq — 语音转录，免费（https://console.groq.com/keys）
GROQ_API_KEY=gsk_xxxxx

# DeepSeek — AI 分析 + 脚本生成（https://platform.deepseek.com/api_keys）
DEEPSEEK_API_KEY=sk-xxxxx

# A2E — 数字人视频，可选（https://a2e.ai）
A2E_API_KEY=a2e_xxxxx

# 服务器端口
PORT=3000
